# Supabase credentials for the demo form.
# Copy to `.env.local` (gitignored) for local dev, and set the SAME two vars in
# the Netlify build environment (Site settings → Environment variables).
# Values: Supabase dashboard → Project Settings → API.
#
# Both are NEXT_PUBLIC_* because the static export inlines them into the client
# bundle at build time. The anon key is safe to expose; RLS (supabase/schema.sql)
# restricts it to inserts only.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
